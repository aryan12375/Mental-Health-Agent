# ─── Groq API (free at console.groq.com) ──────────────────────────────────────
GROQ_API_KEY=GROQ_API_KEY=your_key_here

# ─── Twilio (for safety contact SMS) ──────────────────────────────────────────
# Get free trial at twilio.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ─── App config ───────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
DATABASE_URL=sqlite+aiosqlite:///./companion.db

# ─── Optional: set to "keyword" for fast dev, "distilbert" for real ML ────────
GATEKEEPER_MODE=keyword
